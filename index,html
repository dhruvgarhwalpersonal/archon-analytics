function kpiHTML(c,icon,val,lbl,sub,delta){
  var dHtml=''; if(delta!==undefined&&delta!==null){ var dc=delta>0?'up':delta<0?'down':'flat'; var ds=delta>0?'↑ +':'↓ '; dHtml='<span class="delta '+dc+'">'+(delta!==0?ds:'')+delta+'</span>'; }
  return '<div class="kpi" data-c="'+c+'"><div class="kpi-icon">'+icon+'</div><div class="kpi-val">'+val+'</div><div class="kpi-lbl">'+lbl+'</div><div class="kpi-sub">'+(sub||'')+dHtml+'</div></div>';
}

function renderDashboard(){
  var latest=snapshots[snapshots.length-1], prev=snapshots[snapshots.length-2];
  var fol=latest?latest.followers:0, folDelta=latest&&prev?latest.followers-prev.followers:null;
  var avgReach=reels.length?r(mean(reels.slice(-7).map(function(r){ return r.reach; }))):0;
  var avgER=reels.length?mean(reels.slice(-7).map(er)).toFixed(2):0;
  var totalReels=reels.length;
  var streak=calcStreak();
  var mom=calcMomentum();

  var html='';
  html+=kpiHTML('green','👥',fol.toLocaleString(),'Followers','@be.archon',folDelta);
  html+=kpiHTML('accent','🎬',totalReels,'Total Reels','posted so far');
  html+=kpiHTML('amber','👁️',avgReach.toLocaleString(),'Avg Reach','last 7 reels');
  html+=kpiHTML('purple','⚡',avgER+'%','Avg ER','last 7 reels');
  html+=kpiHTML('teal','🔥',streak,'Day Streak','consecutive posting');
  html+=kpiHTML('rose','📊',mom.score+'/100','Momentum','grade: '+mom.grade);
  document.getElementById('dash-kpis').innerHTML=html;

  // Sidebar
  document.getElementById('sb-followers').textContent=fol.toLocaleString();
  if(folDelta!==null){ var el=document.getElementById('sb-delta'); el.textContent=(folDelta>=0?'↑ +':'')+folDelta+' today'; el.style.color=folDelta>=0?'var(--green)':'var(--red)'; }

  // Heatmap
  renderHeatmap();
  setTimeout(function(){ drawFollowerChart(); drawReachChart(); },100);
}

function calcStreak(){
  if(!reels.length) return 0;
  var dates=new Set(reels.map(function(r){ return r.date; }));
  var cur=0; var d=new Date();
  while(true){
    var key=d.toISOString().split('T')[0];
    if(dates.has(key)){ cur++; d.setDate(d.getDate()-1); }
    else if(cur===0){ d.setDate(d.getDate()-1); var key2=d.toISOString().split('T')[0]; if(dates.has(key2)){cur++;d.setDate(d.getDate()-1);}else break; }
    else break;
    if(cur>365) break;
  }
  return cur;
}

function renderHeatmap(){
  var hm=document.getElementById('heatmap-90'); if(!hm) return;
  var dates={}; reels.forEach(function(r){ dates[r.date]=(dates[r.date]||0)+1; });
  var html=''; var today=new Date();
  for(var i=89;i>=0;i--){
    var d=new Date(today); d.setDate(d.getDate()-i);
    var key=d.toISOString().split('T')[0];
    var cnt=dates[key]||0;
    var bg=cnt===0?'var(--bg3)':cnt===1?'rgba(124,111,255,0.4)':cnt===2?'rgba(124,111,255,0.7)':'rgba(124,111,255,1)';
    html+='<div class="heatmap-cell" style="background:'+bg+'" title="'+key+': '+cnt+' reel(s)"></div>';
  }
  hm.innerHTML=html;
}

