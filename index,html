function submitData(){
  var raw = document.getElementById('paste-input').value;
  if(!raw.trim()){ alert('Nothing to save.'); return; }
  var parsed = parseData(raw);
  var added = 0;

  parsed.snapshots.forEach(function(s){
    var existing = snapshots.findIndex(function(x){ return x.date===s.date; });
    if(existing>=0) snapshots[existing]=s; else snapshots.push(s);
    added++;
  });
  parsed.reels.forEach(function(r){
    var existing = reels.findIndex(function(x){ return x.date===r.date&&x.topic===r.topic&&x.pillar===r.pillar; });
    if(existing>=0) reels[existing]=r; else reels.push(r);
    added++;
  });

  snapshots.sort(function(a,b){ return a.date.localeCompare(b.date); });
  reels.sort(function(a,b){ return a.date.localeCompare(b.date); });
  saveAll();
  closePasteModal();
  document.getElementById('paste-input').value='';
  document.getElementById('parse-preview').style.display='none';
  renderAll();
  alert('✅ Saved '+added+' entries.');
}

