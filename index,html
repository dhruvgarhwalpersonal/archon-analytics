  var CIRC=2*Math.PI*40, dash=(mom.score/100)*CIRC;
  var html='<div class="card-title">⚡ Content Momentum Score <span class="card-sub">8-factor model · weights verified sum 1.00</span></div>';
  html+='<div class="momentum-wrap">'
    +'<svg width="120" height="120" viewBox="0 0 100 100"><circle cx="50" cy="50" r="40" fill="none" stroke="var(--border)" stroke-width="7"/><circle cx="50" cy="50" r="40" fill="none" stroke="'+scoreCol+'" stroke-width="7" stroke-dasharray="'+dash.toFixed(1)+' '+CIRC.toFixed(1)+'" stroke-linecap="round" transform="rotate(-90 50 50)" style="transition:stroke-dasharray .6s ease"/><text x="50" y="46" text-anchor="middle" dominant-baseline="central" font-size="20" font-weight="900" fill="'+scoreCol+'" font-family="DM Mono,monospace">'+mom.score+'</text><text x="50" y="63" text-anchor="middle" font-size="10" fill="var(--text3)" font-family="Poppins,sans-serif">'+mom.grade+'</text></svg>'
    +'<div class="momentum-factors">';
