  var parsed = parseData(raw);
  var prev = document.getElementById('parse-preview');
  var cont = document.getElementById('preview-content');
  var html = '';
  parsed.snapshots.forEach(function(s){
    html += '<div class="preview-item">📅 Snapshot <span>'+s.date+'</span> — Followers: <span>'+s.followers+'</span></div>';
  });
  parsed.reels.forEach(function(r){
