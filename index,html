function renderGrowth(){
  var latest=snapshots[snapshots.length-1];
  var fol=latest?latest.followers:0;
  var MILESTONES=[200,500,1000,5000,10000,50000,100000,500000,1000000];
  var nextMile=MILESTONES.find(function(m){ return m>fol; })||1000000;
  var pct=fol?r(fol/nextMile*100):0;

  var kpis='';
  kpis+=kpiHTML('green','👥',fol.toLocaleString(),'Current Followers','@be.archon');
  kpis+=kpiHTML('accent','🎯',nextMile.toLocaleString(),'Next Milestone',pct+'% there');
  kpis+=kpiHTML('amber','📈',snapshots.length,'Days Tracked','snapshots saved');
  if(snapshots.length>=2){
    var delta=snapshots[snapshots.length-1].followers-snapshots[0].followers;
    var days=snapshots.length;
    var rate=(delta/days).toFixed(1);
    kpis+=kpiHTML('purple','⚡',rate+'/day','Growth Rate','followers per day');
    var daysToNext=rate>0?r((nextMile-fol)/rate):9999;
    kpis+=kpiHTML('teal','⏳',daysToNext>999?'∞':daysToNext+'d','Days to '+nextMile.toLocaleString(),'at current rate');
  }
  document.getElementById('growth-kpis').innerHTML=kpis;

  // Milestones
  var mHTML='';
  MILESTONES.slice(0,7).forEach(function(m){
    var done=fol>=m; var p=done?100:r(fol/m*100);
    var col=done?'var(--green)':'var(--accent)';
    mHTML+='<div style="padding:10px 0;border-bottom:1px solid var(--border)">'
      +'<div style="display:flex;justify-content:space-between;margin-bottom:6px">'
      +'<span style="font-size:12px;font-weight:700;font-family:var(--mono);color:'+col+'">'+m.toLocaleString()+'</span>'
      +'<span style="font-size:10px;color:var(--text3)">'+(done?'✅ Achieved':''+p+'%')+'</span></div>'
      +'<div class="progress-bar"><div class="progress-fill" style="width:'+p+'%;background:'+col+'"></div></div>'
      +'</div>';
  });
  document.getElementById('milestones').innerHTML=mHTML;
  setTimeout(function(){ drawGrowthProjection(); drawDOW(); },100);
}

