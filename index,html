    html+='<div class="mf"><span class="mf-lbl">'+f.lbl+' <span style="opacity:.5;font-size:9px">('+f.w+')</span></span>'
      +'<div class="mf-bar"><div class="mf-fill" style="width:'+f.val+'%;background:'+f.color+'"></div></div>'
