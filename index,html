<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ARCHON Analytics</title>
<link rel="icon" type="image/png" href="icon.png">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --bg:#08080f;--bg2:#0f0f1a;--bg3:#141420;--bg4:#1a1a2a;
  --border:rgba(255,255,255,0.06);--border2:rgba(255,255,255,0.11);
  --text:#e4e4f0;--text2:#9898b8;--text3:#4a4a6a;
  --accent:#7c6fff;--green:#3fcf8e;--amber:#f5a623;--red:#ff5c5c;--purple:#a78bfa;--teal:#00d4aa;--rose:#f43f5e;
  --control:#3a5068;--influence:#6b1a1a;--human:#2d1f4a;--power:#2a2000;--truth:#0f2a0f;
  --font:'Poppins',sans-serif;--mono:'DM Mono',monospace;
  --sidebar:220px;--header:56px;
}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:var(--font);overflow:hidden;}
::-webkit-scrollbar{width:5px;height:5px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:8px;}

/* LAYOUT */
#app{display:flex;height:100vh;}
#sidebar{width:var(--sidebar);background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;overflow:hidden;}
#main{flex:1;display:flex;flex-direction:column;overflow:hidden;}
#header{height:var(--header);background:var(--bg2);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 24px;gap:16px;flex-shrink:0;}
#content{flex:1;overflow-y:auto;padding:24px;}

/* SIDEBAR */
#sidebar-logo{padding:20px 16px 12px;border-bottom:1px solid var(--border);}
#sidebar-logo .logo-name{font-size:18px;font-weight:900;color:var(--text);letter-spacing:.05em;}
#sidebar-logo .logo-sub{font-size:9px;font-weight:700;color:var(--text3);letter-spacing:.12em;text-transform:uppercase;margin-top:2px;}
#sidebar-nav{flex:1;padding:12px 8px;overflow-y:auto;}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;cursor:pointer;font-size:12px;font-weight:700;color:var(--text2);transition:all .15s;margin-bottom:2px;border:1px solid transparent;}
.nav-item:hover{background:var(--bg3);color:var(--text);}
.nav-item.active{background:rgba(124,111,255,0.12);color:var(--accent);border-color:rgba(124,111,255,0.2);}
.nav-item .nav-icon{font-size:15px;width:20px;text-align:center;flex-shrink:0;}
#sidebar-bottom{padding:12px;border-top:1px solid var(--border);}
.followers-badge{background:var(--bg3);border:1px solid var(--border2);border-radius:12px;padding:12px;text-align:center;}
.followers-badge .fb-num{font-size:24px;font-weight:900;color:var(--green);font-family:var(--mono);}
.followers-badge .fb-lbl{font-size:9px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;margin-top:2px;}
.followers-badge .fb-delta{font-size:10px;font-weight:700;color:var(--green);margin-top:4px;}

/* HEADER */
.header-title{font-size:14px;font-weight:900;color:var(--text);flex:1;}
.header-date{font-size:11px;color:var(--text3);font-family:var(--mono);}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 14px;border-radius:10px;border:none;cursor:pointer;font-size:11px;font-weight:700;font-family:var(--font);transition:all .15s;}
.btn-primary{background:var(--accent);color:#fff;}
.btn-primary:hover{background:#6a5fff;}
.btn-ghost{background:var(--bg3);color:var(--text2);border:1px solid var(--border2);}
.btn-ghost:hover{background:var(--bg4);color:var(--text);}
.btn-danger{background:rgba(255,92,92,0.12);color:var(--red);border:1px solid rgba(255,92,92,0.2);}

/* PANELS */
.panel{display:none;flex-direction:column;gap:20px;animation:fadeIn .2s ease;}
.panel.active{display:flex;}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

/* CARDS */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:20px;}
.card-title{font-size:12px;font-weight:900;color:var(--text2);letter-spacing:.04em;text-transform:uppercase;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;gap:8px;}
.card-sub{font-size:10px;color:var(--text3);font-weight:400;text-transform:none;letter-spacing:0;}

/* KPI GRID */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;}
.kpi{background:linear-gradient(145deg,var(--bg3),var(--bg2));border:1px solid var(--border);border-radius:14px;padding:16px;position:relative;overflow:hidden;transition:transform .15s;}
.kpi:hover{transform:translateY(-2px);}
.kpi::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;border-radius:0 0 14px 14px;}
.kpi[data-c=green]::after{background:var(--green);}
.kpi[data-c=accent]::after{background:var(--accent);}
.kpi[data-c=amber]::after{background:var(--amber);}
.kpi[data-c=red]::after{background:var(--red);}
.kpi[data-c=purple]::after{background:var(--purple);}
.kpi[data-c=teal]::after{background:var(--teal);}
.kpi[data-c=rose]::after{background:var(--rose);}
.kpi-icon{font-size:16px;margin-bottom:6px;}
.kpi-val{font-size:22px;font-weight:900;font-family:var(--mono);line-height:1;}
.kpi[data-c=green] .kpi-val{color:var(--green);}
.kpi[data-c=accent] .kpi-val{color:var(--accent);}
.kpi[data-c=amber] .kpi-val{color:var(--amber);}
.kpi[data-c=red] .kpi-val{color:var(--red);}
.kpi[data-c=purple] .kpi-val{color:var(--purple);}
.kpi[data-c=teal] .kpi-val{color:var(--teal);}
.kpi[data-c=rose] .kpi-val{color:var(--rose);}
.kpi-lbl{font-size:9px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);margin-top:4px;}
.kpi-sub{font-size:10px;color:var(--text3);margin-top:2px;}
.delta{font-size:9px;font-weight:700;padding:1px 6px;border-radius:6px;display:inline-block;}
.delta.up{background:rgba(63,207,142,0.12);color:var(--green);}
.delta.down{background:rgba(255,92,92,0.12);color:var(--red);}
.delta.flat{background:rgba(160,160,184,0.1);color:var(--text3);}

/* TWO COL */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.three-col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;}
.chart-wrap{position:relative;min-height:200px;}

/* INSIGHTS */
.insights{display:flex;flex-direction:column;gap:8px;}
.insight{display:flex;align-items:flex-start;gap:12px;padding:12px 14px;border-radius:12px;border:1px solid var(--border);}
.insight.ok{border-color:rgba(63,207,142,0.2);background:rgba(63,207,142,0.04);}
.insight.warn{border-color:rgba(245,166,35,0.2);background:rgba(245,166,35,0.04);}
.insight.crit{border-color:rgba(255,92,92,0.25);background:rgba(255,92,92,0.05);}
.insight.info{border-color:rgba(124,111,255,0.2);background:rgba(124,111,255,0.04);}
.insight-icon{font-size:16px;flex-shrink:0;margin-top:1px;}
.insight-title{font-size:11px;font-weight:700;color:var(--text);margin-bottom:3px;}
.insight-desc{font-size:10px;color:var(--text2);line-height:1.55;}

/* PILLAR BADGES */
.pillar-badge{font-size:9px;font-weight:700;padding:2px 8px;border-radius:6px;display:inline-block;letter-spacing:.05em;}
.pb-CONTROL{background:rgba(58,80,104,0.3);color:#7aafd4;}
.pb-INFLUENCE{background:rgba(107,26,26,0.3);color:#e07070;}
.pb-HUMAN{background:rgba(45,31,74,0.3);color:#b090e0;}
.pb-POWER{background:rgba(42,32,0,0.3);color:#d4a040;}
.pb-TRUTH{background:rgba(15,42,15,0.3);color:#60b060;}

/* REEL TABLE */
.reel-table{width:100%;border-collapse:collapse;font-size:11px;}
.reel-table th{padding:8px 10px;color:var(--text3);text-align:left;border-bottom:1px solid var(--border);font-weight:700;letter-spacing:.04em;font-size:10px;text-transform:uppercase;}
.reel-table td{padding:9px 10px;border-bottom:1px solid var(--border);color:var(--text);}
.reel-table tr:last-child td{border-bottom:none;}
.reel-table tr:hover td{background:rgba(255,255,255,0.02);}
.reel-table .num{font-family:var(--mono);font-weight:700;}
.reel-table .good{color:var(--green);}
.reel-table .med{color:var(--amber);}
.reel-table .bad{color:var(--red);}

/* MOMENTUM RING */
.momentum-wrap{display:flex;align-items:center;gap:24px;}
.momentum-factors{flex:1;display:flex;flex-direction:column;gap:6px;}
.mf{display:flex;align-items:center;gap:8px;}
.mf-lbl{font-size:10px;color:var(--text3);width:200px;flex-shrink:0;}
.mf-bar{flex:1;height:5px;background:var(--border);border-radius:8px;overflow:hidden;}
.mf-fill{height:100%;border-radius:8px;transition:width .6s cubic-bezier(.4,0,.2,1);}
.mf-val{font-size:10px;font-weight:700;color:var(--text2);min-width:30px;text-align:right;font-family:var(--mono);}

/* HEATMAP */
.heatmap{display:flex;flex-wrap:wrap;gap:4px;}
.heatmap-cell{width:16px;height:16px;border-radius:3px;cursor:pointer;position:relative;transition:transform .1s;}
.heatmap-cell:hover{transform:scale(1.3);}
.heatmap-cell[title]:hover::after{content:attr(title);position:absolute;bottom:20px;left:50%;transform:translateX(-50%);background:rgba(10,10,20,.97);color:var(--text);font-size:10px;padding:4px 8px;border-radius:6px;white-space:nowrap;z-index:99;font-family:var(--mono);}

/* PASTE MODAL */
#paste-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.8);backdrop-filter:blur(8px);z-index:1000;align-items:center;justify-content:center;}
#paste-modal.open{display:flex;}
.modal-box{background:var(--bg2);border:1px solid var(--border2);border-radius:20px;padding:28px;width:620px;max-height:80vh;overflow-y:auto;}
.modal-title{font-size:16px;font-weight:900;color:var(--text);margin-bottom:6px;}
.modal-sub{font-size:11px;color:var(--text3);margin-bottom:20px;line-height:1.6;}
.modal-box textarea{width:100%;background:var(--bg3);border:1px solid var(--border2);border-radius:12px;padding:14px;color:var(--text);font-family:var(--mono);font-size:11px;resize:vertical;min-height:220px;outline:none;transition:border-color .15s;line-height:1.7;}
.modal-box textarea:focus{border-color:var(--accent);}
.modal-actions{display:flex;gap:10px;margin-top:14px;justify-content:flex-end;}
.parse-preview{margin-top:14px;background:var(--bg3);border:1px solid var(--border);border-radius:12px;padding:14px;display:none;}
.parse-preview-title{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.07em;margin-bottom:10px;}
.preview-item{font-size:11px;color:var(--text2);margin-bottom:4px;font-family:var(--mono);}
.preview-item span{color:var(--accent);}

/* EMPTY STATE */
.empty{text-align:center;padding:60px 20px;color:var(--text3);}
.empty-icon{font-size:48px;margin-bottom:12px;}
.empty-title{font-size:15px;font-weight:700;color:var(--text2);margin-bottom:6px;}
.empty-sub{font-size:12px;line-height:1.6;}

/* PROGRESS BAR */
.progress-bar{height:6px;background:var(--border);border-radius:8px;overflow:hidden;margin-top:6px;}
.progress-fill{height:100%;border-radius:8px;transition:width .6s cubic-bezier(.4,0,.2,1);}

/* STREAK */
.streak-row{display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-top:8px;}
.streak-dot{width:10px;height:10px;border-radius:2px;}

/* GRADE BADGE */
.grade{display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:10px;font-size:14px;font-weight:900;}
</style>
</head>
<body>
<div id="app">
  <!-- SIDEBAR -->
  <div id="sidebar">
    <div id="sidebar-logo">
      <div class="logo-name">🏛️ ARCHON</div>
      <div class="logo-sub">Analytics Engine</div>
    </div>
    <nav id="sidebar-nav">
      <div class="nav-item active" onclick="switchPanel('dashboard')"><span class="nav-icon">📊</span>Dashboard</div>
      <div class="nav-item" onclick="switchPanel('reels')"><span class="nav-icon">🎬</span>Reels Intelligence</div>
      <div class="nav-item" onclick="switchPanel('pillars')"><span class="nav-icon">🏛️</span>Pillar Analytics</div>
      <div class="nav-item" onclick="switchPanel('growth')"><span class="nav-icon">📈</span>Growth Engine</div>
      <div class="nav-item" onclick="switchPanel('momentum')"><span class="nav-icon">⚡</span>Momentum Score</div>
      <div class="nav-item" onclick="switchPanel('tracker')"><span class="nav-icon">📅</span>Posting Tracker</div>
      <div class="nav-item" onclick="switchPanel('insights')"><span class="nav-icon">💡</span>Insights</div>
    </nav>
    <div id="sidebar-bottom">
      <div class="followers-badge">
        <div class="fb-num" id="sb-followers">—</div>
        <div class="fb-lbl">Followers</div>
        <div class="fb-delta" id="sb-delta">@be.archon</div>
      </div>
    </div>
  </div>

  <!-- MAIN -->
  <div id="main">
    <div id="header">
      <div class="header-title" id="panel-title">Dashboard</div>
      <div class="header-date" id="header-date"></div>
      <button class="btn btn-ghost" onclick="openPasteModal()">📋 Add Data</button>
      <button class="btn btn-ghost" onclick="clearAllData()" style="color:var(--red)">🗑️ Clear</button>
    </div>
    <div id="content">
      <!-- DASHBOARD -->
      <div class="panel active" id="panel-dashboard">
        <div class="kpi-grid" id="dash-kpis"></div>
        <div class="two-col">
          <div class="card"><div class="card-title">📈 Follower Growth <span class="card-sub">daily</span></div><div class="chart-wrap"><canvas id="chart-followers"></canvas></div></div>
          <div class="card"><div class="card-title">👁️ Daily Reach <span class="card-sub">last 14 days</span></div><div class="chart-wrap"><canvas id="chart-reach"></canvas></div></div>
        </div>
        <div class="card"><div class="card-title">📅 90-Day Posting Heatmap</div><div class="heatmap" id="heatmap-90"></div></div>
      </div>

      <!-- REELS -->
      <div class="panel" id="panel-reels">
        <div class="kpi-grid" id="reels-kpis"></div>
        <div class="card"><div class="card-title">🎬 All Reels <span class="card-sub" id="reels-count-label"></span></div><div style="overflow-x:auto"><table class="reel-table" id="reels-table"><thead><tr><th>Date</th><th>Pillar</th><th>Topic</th><th>Plays</th><th>Reach</th><th>Likes</th><th>Saves</th><th>Shares</th><th>ER%</th><th>Save%</th><th>Watch(s)</th><th>Follows</th></tr></thead><tbody id="reels-tbody"></tbody></table></div></div>
        <div class="two-col">
          <div class="card"><div class="card-title">🏆 Top 5 by Plays</div><div id="top-plays"></div></div>
          <div class="card"><div class="card-title">💾 Top 5 by Saves</div><div id="top-saves"></div></div>
        </div>
        <div class="card"><div class="card-title">📊 Reach vs Saves <span class="card-sub">per reel</span></div><div class="chart-wrap"><canvas id="chart-scatter"></canvas></div></div>
      </div>

      <!-- PILLARS -->
      <div class="panel" id="panel-pillars">
        <div class="card"><div class="card-title">🏛️ Pillar Comparison Radar</div><div class="chart-wrap" style="height:320px"><canvas id="chart-radar"></canvas></div></div>
        <div class="three-col" id="pillar-cards"></div>
        <div class="card"><div class="card-title">📊 Posts Per Pillar <span class="card-sub">consistency tracker</span></div><div class="chart-wrap"><canvas id="chart-pillar-bar"></canvas></div></div>
      </div>

      <!-- GROWTH -->
      <div class="panel" id="panel-growth">
        <div class="kpi-grid" id="growth-kpis"></div>
        <div class="card"><div class="card-title">📈 Follower Growth + Projection <span class="card-sub">linear regression</span></div><div class="chart-wrap"><canvas id="chart-growth-proj"></canvas></div></div>
        <div class="card"><div class="card-title">🎯 Milestone Tracker</div><div id="milestones"></div></div>
        <div class="card"><div class="card-title">📅 Day-of-Week Performance</div><div class="chart-wrap"><canvas id="chart-dow"></canvas></div></div>
      </div>

      <!-- MOMENTUM -->
      <div class="panel" id="panel-momentum">
        <div class="card" id="momentum-card"></div>
        <div class="two-col">
          <div class="card"><div class="card-title">📊 Engagement Rate Trend</div><div class="chart-wrap"><canvas id="chart-er-trend"></canvas></div></div>
          <div class="card"><div class="card-title">💾 Save Rate Trend</div><div class="chart-wrap"><canvas id="chart-save-trend"></canvas></div></div>
        </div>
      </div>

      <!-- TRACKER -->
      <div class="panel" id="panel-tracker">
        <div class="kpi-grid" id="tracker-kpis"></div>
        <div class="card"><div class="card-title">🔥 Posting Streak</div><div class="streak-row" id="streak-visual"></div></div>
        <div class="card"><div class="card-title">📅 Weekly Report Cards</div><div id="weekly-reports"></div></div>
      </div>

      <!-- INSIGHTS -->
      <div class="panel" id="panel-insights">
        <div class="card"><div class="card-title">💡 Intelligence Insights <span class="card-sub" id="insights-count"></span></div><div class="insights" id="insights-list"></div></div>
      </div>
    </div>
  </div>
</div>

<!-- PASTE MODAL -->
<div id="paste-modal">
  <div class="modal-box">
    <div class="modal-title">📋 Add ARCHON Data</div>
    <div class="modal-sub">Paste your daily snapshot and/or reel data below.<br>Use the format from the Data Format Guide. Claude extracts this from your screenshots.</div>
    <textarea id="paste-input" placeholder="DATE: 2026-05-10
FOLLOWERS: 161
FOLLOWING: 23
POSTS_TOTAL: 0
PROFILE_VIEWS: 0
REACH_TODAY: 0
IMPRESSIONS_TODAY: 0

REEL_DATE: 2026-05-10
REEL_PILLAR: CONTROL
REEL_TOPIC: The Man Who Needs Nothing
PLAYS: 1240
REACH: 892
LIKES: 67
COMMENTS: 12
SHARES: 23
SAVES: 45
FOLLOWS_FROM: 3
IMPRESSIONS: 1240
AVG_WATCH_TIME: 18
CAPTION_MODE: 2" oninput="livePreview()"></textarea>
    <div class="parse-preview" id="parse-preview">
      <div class="parse-preview-title">✅ Parsed Preview</div>
      <div id="preview-content"></div>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closePasteModal()">Cancel</button>
      <button class="btn btn-primary" onclick="submitData()">💾 Save Data</button>
    </div>
  </div>
</div>

<script>
'use strict';

/* ═══════════════════════════════════════════════
   STORAGE
═══════════════════════════════════════════════ */
var STORE_KEYS = { snapshots:'archon_snapshots', reels:'archon_reels', settings:'archon_settings' };

function loadStore(k){ try{ var d=localStorage.getItem(k); return d?JSON.parse(d):[]; }catch(e){ return []; } }
function saveStore(k,v){ try{ localStorage.setItem(k,JSON.stringify(v)); }catch(e){} }

var snapshots = loadStore(STORE_KEYS.snapshots); // [{date,followers,following,posts_total,profile_views,reach_today,impressions_today}]
var reels = loadStore(STORE_KEYS.reels); // [{date,pillar,topic,plays,reach,likes,comments,shares,saves,follows_from,impressions,avg_watch_time,caption_mode}]

function saveAll(){ saveStore(STORE_KEYS.snapshots,snapshots); saveStore(STORE_KEYS.reels,reels); }

function clearAllData(){
  if(!confirm('Clear ALL ARCHON data? This cannot be undone.')) return;
  snapshots=[]; reels=[];
  saveAll(); renderAll();
}

/* ═══════════════════════════════════════════════
   PARSER
═══════════════════════════════════════════════ */
function parseData(raw){
  var lines = raw.split('\n').map(function(l){ return l.trim(); }).filter(Boolean);
  var result = { snapshots:[], reels:[] };
  var curSnap=null, curReel=null;

  function flushSnap(){ if(curSnap&&curSnap.date){ result.snapshots.push(curSnap); } curSnap=null; }
  function flushReel(){ if(curReel&&curReel.date){ result.reels.push(curReel); } curReel=null; }

  lines.forEach(function(line){
    var m = line.match(/^([A-Z_]+):\s*(.+)$/);
    if(!m) return;
    var key=m[1].trim(), val=m[2].trim();
    var num = parseFloat(val);

    if(key==='DATE'){
      flushSnap(); flushReel();
      curSnap = {date:val,followers:0,following:0,posts_total:0,profile_views:0,reach_today:0,impressions_today:0};
    } else if(key==='REEL_DATE'){
      flushReel();
      curReel = {date:val,pillar:'',topic:'',plays:0,reach:0,likes:0,comments:0,shares:0,saves:0,follows_from:0,impressions:0,avg_watch_time:0,caption_mode:2};
    }

    if(curSnap){
      if(key==='FOLLOWERS') curSnap.followers=num;
      else if(key==='FOLLOWING') curSnap.following=num;
      else if(key==='POSTS_TOTAL') curSnap.posts_total=num;
      else if(key==='PROFILE_VIEWS') curSnap.profile_views=num;
      else if(key==='REACH_TODAY') curSnap.reach_today=num;
      else if(key==='IMPRESSIONS_TODAY') curSnap.impressions_today=num;
    }
    if(curReel){
      if(key==='REEL_PILLAR') curReel.pillar=val.toUpperCase();
      else if(key==='REEL_TOPIC') curReel.topic=val;
      else if(key==='PLAYS') curReel.plays=num;
      else if(key==='REACH') curReel.reach=num;
      else if(key==='LIKES') curReel.likes=num;
      else if(key==='COMMENTS') curReel.comments=num;
      else if(key==='SHARES') curReel.shares=num;
      else if(key==='SAVES') curReel.saves=num;
      else if(key==='FOLLOWS_FROM') curReel.follows_from=num;
      else if(key==='IMPRESSIONS') curReel.impressions=num;
      else if(key==='AVG_WATCH_TIME') curReel.avg_watch_time=num;
      else if(key==='CAPTION_MODE') curReel.caption_mode=num;
    }
  });

  flushSnap(); flushReel();
  return result;
}

function livePreview(){
