function renderTracker(){
  var streak=calcStreak();
  var totalDays=new Set(reels.map(function(r){ return r.date; })).size;
  var target3days=reels.filter(function(r){
    var cnt=reels.filter(function(r2){ return r2.date===r.date; }).length;
    return cnt>=3;
  });
  var kpis='';
  kpis+=kpiHTML('green','🔥',streak,'Current Streak','consecutive days');
  kpis+=kpiHTML('accent','📅',totalDays,'Active Days','days with posts');
  kpis+=kpiHTML('amber','🎬',reels.length,'Total Reels','all time');
  kpis+=kpiHTML('purple','📊',reels.length?r(reels.length/Math.max(1,totalDays)*10)/10:0,'Avg Reels/Day','posting rate');
  document.getElementById('tracker-kpis').innerHTML=kpis;

  // Streak visual (last 30 days)
  var sHTML=''; var today=new Date(); var dates=new Set(reels.map(function(r){ return r.date; }));
  for(var i=29;i>=0;i--){ var d=new Date(today); d.setDate(d.getDate()-i); var key=d.toISOString().split('T')[0]; var has=dates.has(key); sHTML+='<div class="streak-dot" style="background:'+(has?'var(--green)':'var(--bg4)')+';border:1px solid '+(has?'var(--green)':'var(--border)')+'" title="'+key+'"></div>'; }
  document.getElementById('streak-visual').innerHTML=sHTML;

  // Weekly report cards
  var weeks={};
  reels.forEach(function(r){
    var d=new Date(r.date); var mon=new Date(d); mon.setDate(d.getDate()-d.getDay()+1);
    var wk=mon.toISOString().split('T')[0];
    if(!weeks[wk]) weeks[wk]={key:wk,reels:[],dates:new Set()};
    weeks[wk].reels.push(r); weeks[wk].dates.add(r.date);
  });
  var wks=Object.values(weeks).sort(function(a,b){ return b.key.localeCompare(a.key); }).slice(0,8);
  var wHTML='';
  wks.forEach(function(wk){
    var avgE=mean(wk.reels.map(er)).toFixed(2);
    var avgR=r(mean(wk.reels.map(function(r){ return r.reach; })));
    var days=wk.dates.size;
    var col=days>=7?'var(--green)':days>=5?'var(--accent)':days>=3?'var(--amber)':'var(--red)';
    wHTML+='<div style="display:flex;align-items:center;gap:14px;padding:10px 0;border-bottom:1px solid var(--border);font-size:11px">'
      +'<div style="font-family:var(--mono);font-size:10px;color:var(--text3);min-width:80px">'+wk.key+'</div>'
      +'<div style="flex:1"><div style="font-weight:700;color:var(--text)">'+wk.reels.length+' reels · '+days+'/7 days</div>'
      +'<div style="color:var(--text3);margin-top:2px">Avg ER: <span style="color:var(--accent)">'+avgE+'%</span> · Avg Reach: <span style="color:var(--amber)">'+avgR.toLocaleString()+'</span></div></div>'
      +'<div style="width:8px;height:8px;border-radius:50%;background:'+col+'"></div>'
      +'</div>';
  });
  document.getElementById('weekly-reports').innerHTML=wHTML||'<div style="color:var(--text3);font-size:12px;text-align:center;padding:20px">No weekly data yet</div>';
}

