function drawGrowthProjection(){
  destroyChart('growth-proj');
  var c=document.getElementById('chart-growth-proj'); if(!c||snapshots.length<2) return;
  var data=snapshots.slice(-30);
  var n=data.length,sx=0,sy=0,sxy=0,sx2=0;
  for(var i=0;i<n;i++){sx+=i;sy+=data[i].followers;sxy+=i*data[i].followers;sx2+=i*i;}
  var denom=n*sx2-sx*sx; var slope=denom?((n*sxy-sx*sy)/denom):0;
  var intercept=(sy-slope*sx)/n;
  var projLabels=data.map(function(s){ return s.date.slice(5); });
  var projData=data.map(function(s,i){ return r(intercept+slope*i); });
  // extend 14 days
  var lastDate=new Date(data[data.length-1].date);
  for(var j=1;j<=14;j++){var d=new Date(lastDate);d.setDate(d.getDate()+j);projLabels.push((d.getMonth()+1)+'/'+d.getDate());projData.push(r(intercept+slope*(n-1+j)));}
  charts['growth-proj']=new Chart(c,{type:'line',data:{labels:projLabels,datasets:[
    {label:'Actual',data:data.map(function(s){ return s.followers; }).concat(new Array(14).fill(null)),borderColor:'#3fcf8e',backgroundColor:function(ctx){ var ca=ctx.chart.chartArea; return ca?makeGrad(ctx.chart.ctx,ca,'#3fcf8e'):'transparent'; },fill:true,borderWidth:2.5,tension:0.4,pointRadius:3,spanGaps:false},
    {label:'Projected',data:new Array(data.length).fill(null).concat(projData.slice(data.length)),borderColor:'#7c6fff',backgroundColor:'transparent',borderWidth:2,borderDash:[6,4],tension:0.4,pointRadius:0,spanGaps:false}
  ]},options:Object.assign({},baseOpts(),{plugins:Object.assign({},baseOpts().plugins,{legend:{display:true,position:'top',labels:{color:tc(),font:{size:10},boxWidth:10}}})})});
}

