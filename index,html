var PANEL_TITLES={dashboard:'Dashboard',reels:'Reels Intelligence',pillars:'Pillar Analytics',growth:'Growth Engine',momentum:'Momentum Score',tracker:'Posting Tracker',insights:'Insights'};
function switchPanel(id){
  document.querySelectorAll('.panel').forEach(function(p){ p.classList.remove('active'); });
  document.querySelectorAll('.nav-item').forEach(function(n){ n.classList.remove('active'); });
  var p=document.getElementById('panel-'+id);
  var n=document.querySelector('[onclick="switchPanel(\''+id+'\')"]');
  if(p) p.classList.add('active');
  if(n) n.classList.add('active');
  document.getElementById('panel-title').textContent=PANEL_TITLES[id]||id;
  if(id==='dashboard') renderDashboard();
  else if(id==='reels') renderReels();
  else if(id==='pillars') renderPillars();
  else if(id==='growth') renderGrowth();
  else if(id==='momentum') renderMomentum();
  else if(id==='tracker') renderTracker();
  else if(id==='insights') renderInsights();
}

function renderAll(){ switchPanel('dashboard'); }

