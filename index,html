   CALCULATIONS
═══════════════════════════════════════════════ */
var PILLARS = ['CONTROL','INFLUENCE','HUMAN','POWER','TRUTH'];
var PILLAR_COLORS = {CONTROL:'#3a80a0',INFLUENCE:'#c04040',HUMAN:'#8060c0',POWER:'#c0a000',TRUTH:'#40a040'};
var MW = [0.28,0.16,0.15,0.12,0.10,0.08,0.06,0.05];

function er(r){ return r.reach>0?((r.likes+r.comments+r.saves+r.shares)/r.reach*100):0; }
function saveRate(r){ return r.reach>0?(r.saves/r.reach*100):0; }
function shareRate(r){ return r.reach>0?(r.shares/r.reach*100):0; }
function followRate(r){ return r.reach>0?(r.follows_from/r.reach*100):0; }
function mean(arr){ return arr.length?arr.reduce(function(a,b){ return a+b; },0)/arr.length:0; }
function clamp(v,lo,hi){ return Math.min(hi,Math.max(lo,v)); }
function r(v){ return Math.round(v); }

function calcMomentum(){
  if(!reels.length) return {score:0,grade:'F',factors:[]};
  var last14 = reels.slice(-14);
  var last7  = reels.slice(-7);
  var prev7  = reels.slice(-14,-7);

  var f1 = clamp(r(mean(last7.map(er))*10),0,100);
  var days7 = new Set(last7.map(function(r){ return r.date; })).size;
  var f2 = clamp(r(days7/7*100),0,100);
  var recentReach = mean(last7.map(function(r){ return r.reach; }));
  var prevReach   = prev7.length?mean(prev7.map(function(r){ return r.reach; })):recentReach;
  var f3 = prevReach>0?clamp(r(50+(recentReach-prevReach)/prevReach*50),0,100):50;
  var f4 = clamp(r(mean(last7.map(saveRate))*20),0,100);
  var pillarsUsed = new Set(last7.map(function(r){ return r.pillar; })).size;
  var f5 = clamp(r(pillarsUsed/5*100),0,100);
  var f6 = clamp(r(mean(last7.map(function(r){ return r.plays>0?(r.avg_watch_time/28*100):50; }))),0,100);
  var f7 = clamp(r(mean(last7.map(shareRate))*50),0,100);
  var f8 = clamp(r(mean(last7.map(followRate))*100),0,100);

  var score = clamp(r(MW[0]*f1+MW[1]*f2+MW[2]*f3+MW[3]*f4+MW[4]*f5+MW[5]*f6+MW[6]*f7+MW[7]*f8),0,100);
  var grade = score>=92?'A+':score>=82?'A':score>=72?'B+':score>=62?'B':score>=50?'C':score>=38?'D':'F';

  return {score:score,grade:grade,factors:[
    {lbl:'Avg Engagement Rate (×10)',val:f1,color:'#7c6fff',w:'28%'},
    {lbl:'Posting Consistency (7d)',val:f2,color:'#a78bfa',w:'16%'},
    {lbl:'Reach Trend Direction',val:f3,color:f3>=55?'#3fcf8e':f3<=45?'#ff5c5c':'#f5a623',w:'15%'},
    {lbl:'Save Rate (×20)',val:f4,color:'#f5a623',w:'12%'},
    {lbl:'Pillar Coverage',val:f5,color:'#00d4aa',w:'10%'},
    {lbl:'Watch Time Score',val:f6,color:'#fb923c',w:'8%'},
    {lbl:'Share Rate (×50)',val:f7,color:'#f43f5e',w:'6%'},
    {lbl:'Follower Conversion',val:f8,color:'#38bdf8',w:'5%'}
  ]};
}

function pillarStats(pillar){
  var pr = reels.filter(function(r){ return r.pillar===pillar; });
  if(!pr.length) return null;
  return {
    count:pr.length,
    avgPlays:r(mean(pr.map(function(r){ return r.plays; }))),
    avgReach:r(mean(pr.map(function(r){ return r.reach; }))),
    avgER:mean(pr.map(er)).toFixed(2),
    avgSaves:r(mean(pr.map(function(r){ return r.saves; }))),
    avgShares:r(mean(pr.map(function(r){ return r.shares; }))),
    best:pr.reduce(function(a,b){ return er(a)>er(b)?a:b; }),
    worst:pr.reduce(function(a,b){ return er(a)<er(b)?a:b; })
  };
}

function generateInsights(){
  var ins=[];
  if(!reels.length&&!snapshots.length){ return [{type:'info',icon:'📋',title:'No data yet',desc:'Click "Add Data" and paste your daily Instagram metrics to unlock ARCHON Analytics.'}]; }

  var last7 = reels.slice(-7);
  var prev7 = reels.slice(-14,-7);
  var latestSnap = snapshots[snapshots.length-1];
  var prevSnap = snapshots[snapshots.length-2];

  // Follower growth signal
  if(latestSnap&&prevSnap){
    var delta = latestSnap.followers - prevSnap.followers;
    if(delta>10) ins.push({type:'ok',icon:'🚀',title:'Strong follower growth: +'+delta+' from last snapshot',desc:'Gaining followers at this pace. Identify which reels drove this spike and replicate the format.'});
    else if(delta<0) ins.push({type:'crit',icon:'📉',title:'Follower loss: '+delta+' since last snapshot',desc:'Net negative growth. Analyze what changed — posting frequency, content quality, or audience mismatch.'});
  }

  // Engagement rate analysis
  if(last7.length){
    var avgER7 = mean(last7.map(er));
    var avgER_prev = prev7.length?mean(prev7.map(er)):avgER7;
    var erDelta = r(avgER7-avgER_prev);
    if(avgER7>=5) ins.push({type:'ok',icon:'⚡',title:'Excellent engagement rate: '+avgER7.toFixed(2)+'%',desc:'Above 5% ER is viral territory. ARCHON content is deeply resonating. Double down on this week\'s format.'});
    else if(avgER7>=2&&avgER7<5) ins.push({type:'info',icon:'📊',title:'Solid engagement: '+avgER7.toFixed(2)+'%',desc:'2-5% ER is healthy. Push saves and shares to break into the 5%+ tier.'});
    else if(avgER7<2&&last7.length>=3) ins.push({type:'warn',icon:'⚠️',title:'Low engagement: '+avgER7.toFixed(2)+'%',desc:'Below 2% suggests hook or content issue. Test shorter scripts and stronger opening lines.'});
    if(erDelta>1) ins.push({type:'ok',icon:'📈',title:'Engagement rate improving: +'+erDelta+'% week-over-week',desc:'Upward ER trend = content is getting better. Continue refining scripts using current direction.'});
    else if(erDelta<-1) ins.push({type:'warn',icon:'📉',title:'Engagement rate declining: '+erDelta+'% week-over-week',desc:'Downward ER trend. Do not change too many variables at once — isolate and fix one element.'});
  }

  // Pillar coverage
  var pillarsThisWeek = new Set(last7.map(function(r){ return r.pillar; }));
  var missingPillars = PILLARS.filter(function(p){ return !pillarsThisWeek.has(p); });
  if(missingPillars.length>0&&last7.length>=3) ins.push({type:'warn',icon:'🏛️',title:'Pillar rotation incomplete: missing '+missingPillars.join(', '),desc:'Missing pillars reduce audience diversity. Post one '+missingPillars[0]+' reel today to restore the rotation.'});
  else if(last7.length>=5&&missingPillars.length===0) ins.push({type:'ok',icon:'✅',title:'Perfect pillar rotation this week',desc:'All 5 pillars covered. This maximizes audience reach across different interest segments.'});

  // Save rate signal
  if(last7.length){
    var avgSR = mean(last7.map(saveRate));
    if(avgSR>=5) ins.push({type:'ok',icon:'💾',title:'High save rate: '+avgSR.toFixed(2)+'%',desc:'Above 5% save rate means ARCHON content has extreme value. Saved content gets re-shown by Instagram — this is your growth lever.'});
    else if(avgSR<2&&last7.length>=3) ins.push({type:'warn',icon:'💾',title:'Low save rate: '+avgSR.toFixed(2)+'%',desc:'Low saves means content is consumed but not valued. Mode 1 (list) captions drive more saves than Mode 2. Try adding the "read caption" hook to next reel.'});
  }

  // Posting consistency
  if(snapshots.length>=7){
    var last7dates = [];
    var today = new Date(); 
    for(var i=0;i<7;i++){ var d=new Date(today); d.setDate(d.getDate()-i); last7dates.push(d.toISOString().split('T')[0]); }
    var posted7 = new Set(reels.filter(function(r){ return last7dates.indexOf(r.date)>=0; }).map(function(r){ return r.date; })).size;
    if(posted7>=7) ins.push({type:'ok',icon:'🔥',title:'Perfect posting streak: 7+ consecutive days',desc:'7-day streak is ARCHON\'s most important metric. The algorithm rewards consistent accounts heavily.'});
    else if(posted7<5) ins.push({type:'crit',icon:'🚨',title:'Inconsistent posting: only '+posted7+'/7 days this week',desc:'Posting gaps kill algorithmic momentum. Even 1 reel per day minimum. Batch 3 reels every Sunday to protect your streak.'});
  }

  // Best performing pillar
  var pillarERs = PILLARS.map(function(p){ var s=pillarStats(p); return s?{p:p,er:parseFloat(s.avgER)}:null; }).filter(Boolean);
  if(pillarERs.length>1){
    pillarERs.sort(function(a,b){ return b.er-a.er; });
    var best=pillarERs[0], worst=pillarERs[pillarERs.length-1];
    ins.push({type:'ok',icon:'🏆',title:'Best pillar: '+best.p+' ('+best.er.toFixed(2)+'% avg ER)',desc:best.p+' content performs highest. Ensure it gets posted at least twice per week. Analyze what makes '+best.p+' reels outperform.'});
    if(worst.er<1&&pillarERs.length>=3) ins.push({type:'warn',icon:'⚠️',title:'Weakest pillar: '+worst.p+' ('+worst.er.toFixed(2)+'% avg ER)',desc:worst.p+' content is underperforming. Either improve script quality for this pillar or temporarily reduce its frequency.'});
  }

  // Watch time analysis
  if(last7.length){
    var avgWT = mean(last7.map(function(r){ return r.avg_watch_time; }));
    if(avgWT>20) ins.push({type:'ok',icon:'⏱️',title:'Strong watch time: '+r(avgWT)+'s average',desc:'High watch time tells Instagram your content is engaging. The algorithm rewards this with wider distribution.'});
    else if(avgWT<10&&last7.length>=3) ins.push({type:'warn',icon:'⏱️',title:'Low watch time: '+r(avgWT)+'s average',desc:'Low watch time means people are dropping off fast. Check if hooks are strong enough and if script is paced correctly.'});
  }

  // Reach trend
  if(last7.length&&prev7.length){
    var rR=mean(last7.map(function(r){ return r.reach; })), pR=mean(prev7.map(function(r){ return r.reach; }));
    var rDelta=pR>0?r((rR-pR)/pR*100):0;
    if(rDelta>=20) ins.push({type:'ok',icon:'📡',title:'Reach surging: +'+rDelta+'% week-over-week',desc:'Major reach increase signals the algorithm is pushing ARCHON content. Do NOT change what you are doing.'});
    else if(rDelta<=-20) ins.push({type:'crit',icon:'📡',title:'Reach dropping: '+rDelta+'% week-over-week',desc:'Significant reach decline. Check posting time consistency and content quality. Hashtags may need rotation.'});
  }

  // Volume signal
  if(reels.length>0){
    var totalReels=reels.length, totalPlays=reels.reduce(function(a,r){ return a+r.plays; },0);
    ins.push({type:'info',icon:'📊',title:'Total content: '+totalReels+' reels · '+totalPlays.toLocaleString()+' plays',desc:'Building the content library. At current pace, reaching 100 reels is the first major credibility milestone.'});
  }

  return ins;
}

